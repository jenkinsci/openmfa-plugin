# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file
root = true

# Unix-style newlines with a newline ending every file
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

# Java source files
[*.java]
indent_style = space
indent_size = 2
max_line_length = 86
continuation_indent_size = 2

# XML files (pom.xml, config files)
[*.xml]
indent_style = space
indent_size = 2

# Groovy files (Jenkinsfile, etc.)
[*.groovy]
indent_style = space
indent_size = 2

[Jenkinsfile]
indent_style = space
indent_size = 2

# Properties files
[*.properties]
indent_style = space
indent_size = 2

# Jelly files (Jenkins UI)
[*.jelly]
indent_style = space
indent_size = 2

# Markdown files
[*.md]
indent_style = space
indent_size = 2
max_line_length = off
trim_trailing_whitespace = false

# YAML files
[*.{yml,yaml}]
indent_style = space
indent_size = 2

# JSON files
[*.json]
indent_style = space
indent_size = 2

