{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "maven: hpi:run",
      "type": "shell",
      "command": "./mvnw",
      "args": ["hpi:run", "-Dhost=0.0.0.0"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": [],
      "isBackground": true
    },
    {
      "label": "maven: hpi:run (debug)",
      "type": "shell",
      "command": "./mvnw",
      "args": ["clean", "-U", "hpi:run", "-Dhost=0.0.0.0"],
      "options": {
        "cwd": "${workspaceFolder}",
        "envFile": "${workspaceFolder}/.env",
        "env": {
          "JAVA_HOME": "${env:JAVA_HOME}",
          "MAVEN_OPTS": "-agentlib:jdwp=transport=dt_socket,server=y,suspend=n,address=*:5005"
        }
      },
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": {
        "owner": "jenkins-hpi",
        "pattern": {
          "regexp": "^$"
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*Listening for transport dt_socket.*$",
          "endsPattern": "^.*Jenkins is fully up and running.*$"
        }
      },
      "isBackground": true
    },
    {
      "label": "mvnDebug: clean hpi:run",
      "type": "shell",
      "command": "mvnDebug",
      "args": ["-U", "clean", "hpi:run", "-Dhost=0.0.0.0"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": [],
      "isBackground": true
    },
    {
      "label": "maven: test",
      "type": "shell",
      "command": "./mvnw",
      "args": ["test"],
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "maven: clean install",
      "type": "shell",
      "command": "./mvnw",
      "args": ["clean", "install", "-DskipTests"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    },
    {
      "label": "maven: clean install (with tests)",
      "type": "shell",
      "command": "./mvnw",
      "args": ["clean", "install"],
      "group": "build",
      "presentation": {
        "reveal": "always",
        "panel": "dedicated"
      },
      "problemMatcher": []
    }
  ]
}
